
# Database
# MongoDB connection string format: mongodb+srv://username:password@cluster.mongodb.net/database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# Telegram Bot
TELEGRAM_BOT_TOKEN="123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ"
TELEGRAM_CHAT_ID="123456789"

# Authentication
# Use a long, random string for secrets in production. You can generate one using a tool like openssl or an online generator.
# Example: openssl rand -base64 32 for a 32-byte random string.
ADMIN_SECRET="your_admin_secret_here"
BETTER_AUTH_SECRET="your_better_auth_secret_here_make_it_long_and_random"

# The URL used for Better Auth redirects and callbacks
BETTER_AUTH_URL=https://yourdomain.com

# The URL used by the client-side auth (matching lib/auth-client.ts)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Cloudflare R2
# Cloudflare R2 configuration for storing images. Make sure to replace these with your actual Cloudflare R2 credentials and bucket information.
CLOUDFLARE_R2_ENDPOINT="https://your_account_id.r2.cloudflarestorage.com"
CLOUDFLARE_R2_BUCKET="your_bucket_name"
CLOUDFLARE_R2_UPLOAD_PREFIX="your_upload_prefix" # e.g., "portfolio/images"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_secret_access_key"
NEXT_PUBLIC_CLOUDFLARE_R2_BASE_URL="https://your_custom_domain_or_r2_endpoint/your_upload_prefix"

# Last.fm API
# Last.fm API key and username for fetching music data. You can obtain an API key by creating an account on Last.fm and registering for API access.
# Example: https://www.last.fm/api/account/create
LASTFM_API_KEY="your_lastfm_api_key_here"
LASTFM_USERNAME="your_lastfm_username_here"